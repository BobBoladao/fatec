{t:"Genética",q:"DNA é formado por nucleotídeos compostos de:",o:["Fosfato + açúcar (desoxirribose) + base nitrogenada","Apenas aminoácidos","Lipídios + proteínas","RNA + proteínas"],c:0,w:"Nucleotídeo do DNA: grupo fosfato + desoxirribose + base (A, T, C ou G)."},
{t:"Genética",q:"A regra de Chargaff estabelece que no DNA:",o:["A=T e C≡G (bases se emparelham complementarmente)","A=C e T=G","Todas as bases são iguais","RNA e DNA têm as mesmas bases"],c:0,w:"Chargaff: Adenina=Timina; Citosina=Guanina. Emparelhamento específico na dupla hélice."},
{t:"Genética",q:"Genótipo AA é:",o:["Homozigoto dominante","Heterozigoto","Homozigoto recessivo","Hemizigoto"],c:0,w:"AA = homozigoto dominante (dois alelos dominantes iguais)."},
{t:"Genética",q:"No cruzamento Aa × Aa, a proporção fenotípica esperada é:",o:["3 dominante : 1 recessivo","1:1","1:2:1","Todos dominantes"],c:0,w:"Aa×Aa: 1/4 AA, 2/4 Aa, 1/4 aa → fenotipicamente 3 dominantes : 1 recessivo."},
{t:"Genética",q:"Mutação é:",o:["Alteração na sequência de DNA que pode afetar a expressão gênica","Sempre letal","Sempre benéfica","Transmitida apenas por vírus"],c:0,w:"Mutação: alteração na sequência de bases do DNA. Pode ser neutra, benéfica ou prejudicial."},
{t:"Genética",q:"(FATEC) A síndrome de Down é causada por:",o:["Trissomia do cromossomo 21 (47 cromossomos no total)","Monossomia do cromossomo X","Deleção no cromossomo 5","Inversão cromossômica"],c:0,w:"Síndrome de Down (trissomia 21): três cópias do cromossomo 21 → 47 cromossomos."},
{t:"Ecologia",q:"Cadeia alimentar começa sempre com:",o:["Produtor (vegetal autótrofo)","Consumidor primário","Decompositor","Carnívoro"],c:0,w:"Cadeia: Produtor → Consumidor 1° → Consumidor 2° → Decompositor. Energia flui dos produtores."},
{t:"Ecologia",q:"Em cada nível trófico, a energia disponível para o próximo nível é aproximadamente:",o:["10%","50%","90%","100%"],c:0,w:"Regra dos 10%: apenas ~10% da energia de um nível trófico passa para o próximo."},
{t:"Ecologia",q:"Simbiose mutualística é aquela em que:",o:["Ambos os organismos se beneficiam (ex: fungos e algas no líquen)","Um se beneficia e o outro é prejudicado","Um se beneficia e o outro é neutro","Ambos são prejudicados"],c:0,w:"Mutualismo: os dois organismos se beneficiam (ex: abelha e flor, bactérias intestinais e humanos)."},
{t:"Ecologia",q:"(FATEC) O principal responsável pela destruição da camada de ozônio é:",o:["CFC (clorofluorcarboneto)","CO₂","CH₄","SO₂"],c:0,w:"CFCs liberam cloro na estratosfera, que catalisa a destruição do O₃ (ozônio)."},
{t:"Ecologia",q:"Bioma brasileiro de maior biodiversidade:",o:["Amazônia","Cerrado","Mata Atlântica","Caatinga"],c:0,w:"Amazônia: maior biodiversidade do planeta. Mata Atlântica: mais ameaçada (restam ~12% da cobertura original)."},
{t:"Fisiologia",q:"Qual órgão produz bile para auxiliar na digestão de gorduras?",o:["Fígado","Pâncreas","Estômago","Rim"],c:0,w:"Fígado produz bile (armazenada na vesícula biliar), que emulsiona gorduras no intestino delgado."},
{t:"Fisiologia",q:"O pâncreas produz insulina, hormônio que:",o:["Reduz a glicemia (glicose no sangue) estimulando sua absorção pelas células","Aumenta a glicemia","Regula pressão arterial","Controla temperatura corporal"],c:0,w:"Insulina: produzida pelas células β do pâncreas. Facilita a entrada de glicose nas células → reduz glicemia."},
{t:"Fisiologia",q:"A função dos rins é:",o:["Filtrar o sangue, eliminar toxinas e regular equilíbrio hidroeletrolítico","Produzir bile","Realizar trocas gasosas","Bombar sangue"],c:0,w:"Rins: filtração do sangue, excreção de ureia e outras toxinas, regulação do balanço hídrico e salino."},
{t:"Fisiologia",q:"Glóbulos vermelhos (eritrócitos) transportam:",o:["O₂ ligado à hemoglobina","CO₂ apenas","Anticorpos","Hormônios"],c:0,w:"Eritrócitos: transportam O₂ via hemoglobina (proteína com Fe²⁺). Também transportam CO₂ de volta."},
{t:"Fisiologia",q:"O sistema nervoso central é formado por:",o:["Encéfalo (cérebro, cerebelo, tronco) e medula espinhal","Apenas o cérebro","Nervos periféricos","Coração e pulmões"],c:0,w:"SNC: encéfalo + medula espinhal. SNP: nervos e gânglios fora do SNC."},
{t:"Evolução",q:"A Teoria da Evolução por Seleção Natural foi proposta por:",o:["Charles Darwin (e Alfred Wallace)","Gregor Mendel","Louis Pasteur","Jean-Baptiste Lamarck"],c:0,w:"Darwin (e Wallace independentemente): seleção natural — organismos mais adaptados sobrevivem e reproduzem mais."},
{t:"Evolução",q:"O mecanismo central da evolução Darwiniana é:",o:["Seleção natural: sobrevivem os mais adaptados ao ambiente","Herança de caracteres adquiridos","Mutação dirigida","Criação especial"],c:0,w:"Seleção natural: variação + hereditariedade + pressão ambiental → sobrevivência diferencial."},
{t:"Evolução",q:"Analogia em evolução se refere a:",o:["Estruturas com função semelhante mas origem evolutiva diferente (ex: asa de inseto e asa de ave)","Estruturas com mesma origem mas função diferente","Genes idênticos em espécies diferentes","Sequências de DNA conservadas"],c:0,w:"Analogia: função similar, origem diferente (evolução convergente). Homologia: origem comum, funções podem diferir."},
{t:"Evolução",q:"(FATEC) Deriva genética é mais significativa em:",o:["Populações pequenas (variação aleatória do pool gênico)","Populações grandes","Ambientes estáveis","Espécies com muitos filhotes"],c:0,w:"Deriva genética: mudança aleatória nas frequências alélicas. Efeito maior em populações pequenas."},
{t:"Vírus e bactérias",q:"Vírus são acelulares e se reproduzem:",o:["Apenas dentro de células hospedeiras (parasitas intracelulares obrigatórios)","De forma independente em qualquer meio","Por bipartição","Por meiose"],c:0,w:"Vírus: não têm metabolismo próprio. Invadem células hospedeiras e usam sua maquinaria para se replicar."},
{t:"Vírus e bactérias",q:"Antibióticos são eficazes contra:",o:["Bactérias (não funcionam contra vírus)","Vírus","Fungos apenas","Todos os patógenos"],c:0,w:"Antibióticos: combatem bactérias. Não têm efeito sobre vírus (que não têm as estruturas-alvo)."},
{t:"Vírus e bactérias",q:"(FATEC) A vacinação funciona por:",o:["Estimular o sistema imune a produzir memória contra o patógeno antes do contato real","Destruir vírus diretamente","Substituir antibióticos","Matar bactérias no sangue"],c:0,w:"Vacinas: antígenos (mortos/atenuados) ativam produção de anticorpos e células de memória imunológica."},
{t:"Botânica",q:"Fotossíntese ocorre nos cloroplastos. A equação geral é:",o:["6CO₂+6H₂O→C₆H₁₂O₆+6O₂ (com energia luminosa)","6O₂+6H₂O→CO₂+energia","C₆H₁₂O₆+O₂→CO₂+H₂O+ATP","CO₂+luz→O₂"],c:0,w:"Fotossíntese: CO₂+H₂O+luz→glicose+O₂. Produtores captam energia solar e fixam C."},
{t:"Botânica",q:"Respiração celular aeróbia: a equação geral é:",o:["C₆H₁₂O₆+6O₂→6CO₂+6H₂O+ATP","6CO₂+6H₂O→C₆H₁₂O₆+O₂","CO₂+H₂O→glicose","Glicose+ATP→CO₂"],c:0,w:"Respiração: glicose+O₂→CO₂+H₂O+ATP (energia). Ocorre nas mitocôndrias."},
{t:"Botânica",q:"Transpiraçãovegetal serve para:",o:["Transporte de seiva bruta pelo xilema (força motriz) e regulação de temperatura","Fotossíntese diretamente","Absorção de nutrientes","Produção de flores"],c:0,w:"Transpiração: perda de água pelos estômatos cria tensão que 'puxa' a seiva bruta pelo xilema."},
{t:"Saúde",q:"(FATEC) Dengue, zika e chikungunya são transmitidos pelo mosquito:",o:["Aedes aegypti","Anopheles","Culex","Simulium"],c:0,w:"Aedes aegypti: vetor da dengue, zika, chikungunya e febre amarela urbana."},
{t:"Saúde",q:"HIV causa AIDS ao destruir principalmente:",o:["Linfócitos T CD4⁺ (células de defesa)","Eritrócitos","Neurônios","Células hepáticas"],c:0,w:"HIV destrói linfócitos TCD4⁺ → imunossupressão → AIDS (doenças oportunistas)."},
{t:"Saúde",q:"O colesterol LDL é conhecido como 'ruim' porque:",o:["Deposita colesterol nas paredes das artérias (aterosclerose)","Remove colesterol das artérias","Produz hormônios","Transporta vitaminas"],c:0,w:"LDL: leva colesterol do fígado para os tecidos → pode se depositar nas artérias → placa de ateroma."},
{t:"Genética e biotecnologia",q:"PCR (Reação em Cadeia da Polimerase) é técnica usada para:",o:["Amplificar (multiplicar) sequências específicas de DNA","Sequenciar proteínas","Fabricar anticorpos","Realizar fecundação in vitro"],c:0,w:"PCR: amplifica fragmentos específicos de DNA exponencialmente. Usada em diagnósticos, pesquisa e forense."},
{t:"Genética e biotecnologia",q:"OGM (Organismo Geneticamente Modificado) é aquele que:",o:["Recebeu gene(s) de outra espécie por engenharia genética","Sofreu mutação natural","É criado por seleção artificial tradicional","É clonado"],c:0,w:"OGM: organismo cujo DNA foi alterado com inserção de gene(s) exógenos por técnicas de engenharia genética."},
{t:"Ecologia urbana",q:"(FATEC) Ilhas de calor urbanas resultam principalmente de:",o:["Substituição da vegetação por superfícies impermeáveis que retêm e irradiam calor","Excesso de chuvas","Alta altitude das cidades","Correntes marítimas"],c:0,w:"Ilhas de calor: asfalto e concreto absorvem calor e o irradiam. Falta de vegetação elimina a evapotranspiração refrescante."}
]},

