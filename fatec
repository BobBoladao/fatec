<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FATEC ADS — Simulado Completo</title>
<style>
:root{
  --navy:#0a1628;--blue:#1a4aff;--blue2:#3a6aff;--bluek:#e8eeff;
  --gold:#f5a623;--gold2:#fff3d6;
  --green:#00c97a;--greenl:#e0fff2;
  --red:#e8333a;--redl:#ffeaea;
  --warn:#e07b00;--warnl:#fff4e0;
  --bg:#f0f2f7;--card:#fff;--ink:#0a1628;--muted:#5a6380;--line:#dde1ea;
  --r:14px;--sh:0 2px 14px rgba(0,0,0,.07),0 1px 3px rgba(0,0,0,.04);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{min-height:100%;font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--ink)}
.screen{display:none;min-height:100vh;padding:20px 16px 80px;animation:fi .2s ease}
.screen.on{display:block}
@keyframes fi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.inner{max-width:600px;margin:0 auto}

/* HOME */
.home{display:none;min-height:100vh;padding:24px 16px 60px}
.home.on{display:block}
.home-inner{max-width:600px;margin:0 auto}
.home-top{text-align:center;padding-top:16px;margin-bottom:28px}
.home-badge{font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:900;color:var(--gold);background:var(--navy);padding:5px 14px;border-radius:99px;display:inline-block;margin-bottom:14px}
.home-title{font-size:30px;font-weight:900;letter-spacing:-1px;line-height:1.1;color:var(--navy);margin-bottom:6px}
.home-title span{color:var(--blue)}
.home-sub{font-size:14px;color:var(--muted);line-height:1.5}
.section-label{font-size:11px;text-transform:uppercase;letter-spacing:.18em;font-weight:800;color:var(--muted);margin:20px 0 10px;padding-left:2px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.scard{border-radius:12px;padding:14px 12px;cursor:pointer;transition:transform .14s,box-shadow .14s;border:2px solid transparent;text-align:center;position:relative}
.scard:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(0,0,0,.13)}
.scard:active{transform:scale(.98)}
.scard-ico{font-size:26px;margin-bottom:6px}
.scard-name{font-size:13px;font-weight:800;line-height:1.2}
.scard-desc{font-size:10px;opacity:.7;margin-top:3px;line-height:1.3}
.weight-tag{font-size:9px;font-weight:900;padding:2px 7px;border-radius:5px;margin-top:6px;display:inline-block}

/* color themes per subject */
.c-mat{background:var(--navy);border-color:var(--blue2);color:#fff}
.c-mat .weight-tag{background:var(--blue);color:#fff}
.c-log{background:#1a0a2e;border-color:var(--gold);color:#fff}
.c-log .weight-tag{background:var(--gold);color:var(--navy)}
.c-por{background:#1a3a0a;border-color:#4caf50;color:#fff}
.c-por .weight-tag{background:#4caf50;color:#fff}
.c-ing{background:#0a2a3a;border-color:#00bcd4;color:#fff}
.c-ing .weight-tag{background:#00bcd4;color:#fff}
.c-fis{background:#2a0a0a;border-color:#f44336;color:#fff}
.c-fis .weight-tag{background:#f44336;color:#fff}
.c-qui{background:#1a0a3a;border-color:#9c27b0;color:#fff}
.c-qui .weight-tag{background:#9c27b0;color:#fff}
.c-bio{background:#0a2a1a;border-color:#8bc34a;color:#fff}
.c-bio .weight-tag{background:#8bc34a;color:#fff}
.c-his{background:#3a2a0a;border-color:#ff9800;color:#fff}
.c-his .weight-tag{background:#ff9800;color:#fff}
.c-geo{background:#0a3a2a;border-color:#00bfa5;color:#fff}
.c-geo .weight-tag{background:#00bfa5;color:#fff}
.home-note{background:var(--card);border-radius:var(--r);padding:14px 16px;border:1.5px solid var(--line);font-size:13px;color:var(--muted);line-height:1.55;margin-top:12px}
.home-note strong{color:var(--blue)}

/* QUIZ HEADER */
.qhdr{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.hbtn{background:none;border:none;cursor:pointer;font-size:22px;padding:4px 8px 4px 0;color:var(--muted);line-height:1}
.qhdr-info{flex:1;min-width:0}
.qhdr-name{font-size:10px;text-transform:uppercase;letter-spacing:.15em;font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qhdr-meta{font-size:12px;color:var(--muted)}
.spill{background:var(--card);border:1.5px solid var(--line);border-radius:99px;padding:5px 11px;font-size:13px;font-weight:800;white-space:nowrap;flex:none}
.pgrow{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.pgbar{flex:1;height:5px;background:var(--line);border-radius:99px;overflow:hidden}
.pgfill{height:100%;border-radius:99px;transition:width .3s}
.pglbl{font-size:11px;color:var(--muted);white-space:nowrap}
.dotrow{display:flex;gap:3px;flex-wrap:wrap;margin-bottom:14px}
.d{width:9px;height:9px;border-radius:50%;background:var(--line);cursor:pointer;flex:none;transition:background .12s,transform .1s}
.d.ok{background:var(--green)}
.d.wrong{background:var(--red)}
.d.cur{transform:scale(1.5)}
.qcard{background:var(--card);border-radius:var(--r);padding:20px;box-shadow:var(--sh);margin-bottom:10px}
.qtag{font-size:10px;text-transform:uppercase;letter-spacing:.14em;font-weight:800;color:var(--muted);margin-bottom:8px}
.qn{font-weight:900}
.qtext{font-size:16px;font-weight:600;line-height:1.55}
.opt{display:flex;gap:10px;align-items:flex-start;width:100%;text-align:left;background:var(--card);border:1.5px solid var(--line);border-radius:11px;padding:12px 14px;margin-top:8px;cursor:pointer;font-size:14px;line-height:1.4;color:var(--ink);transition:border-color .1s,background .1s;word-break:break-word}
.opt:disabled{cursor:default}
.ol{flex:none;width:24px;height:24px;border-radius:6px;display:grid;place-items:center;font-size:11px;font-weight:800;background:var(--bg);border:1.5px solid var(--line);color:var(--muted)}
.opt.ok{border-color:var(--green)!important;background:var(--greenl)!important}
.opt.ok .ol{background:var(--green);color:#fff;border-color:var(--green)}
.opt.err{border-color:var(--red)!important;background:var(--redl)!important}
.opt.err .ol{background:var(--red);color:#fff;border-color:var(--red)}
.opt.dim{opacity:.35}
.fb{border-radius:var(--r);padding:14px;margin-top:10px;border:1.5px solid}
.fb.ok{background:var(--greenl);border-color:#8ae0c0}
.fb.err{background:var(--redl);border-color:#f5b0b3}
.fb-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:8px}
.fb-ico{font-size:20px;flex:none}
.fb-v{font-weight:900;font-size:15px}
.fb.ok .fb-v{color:var(--green)}
.fb.err .fb-v{color:var(--red)}
.fb-why{font-size:13px;color:#444;line-height:1.6;margin-top:6px}
.listbtn{width:100%;background:none;border:1.5px solid var(--line);border-radius:11px;padding:10px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;margin-top:8px}
.listbtn:hover{background:var(--line)}
.navrow{display:flex;gap:8px;margin-top:10px}
.nb{flex:1;border:none;border-radius:11px;padding:13px;font-size:14px;font-weight:800;cursor:pointer;transition:opacity .12s,transform .1s}
.nb:active{transform:scale(.98)}
.nb.prev{background:var(--card);border:1.5px solid var(--line);color:var(--ink)}
.nb:disabled{opacity:.3;cursor:default}
.foot{text-align:center;font-size:11px;color:var(--muted);margin-top:14px}
.mov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:200;align-items:flex-end;justify-content:center}
.mov.on{display:flex}
.mbox{background:var(--card);border-radius:var(--r) var(--r) 0 0;padding:20px;width:100%;max-width:600px;max-height:70vh;overflow-y:auto}
.mhdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.mtit{font-weight:900;font-size:16px}
.mx{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted)}
.qgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(46px,1fr));gap:6px}
.qi{border:1.5px solid var(--line);border-radius:8px;padding:7px 4px;text-align:center;cursor:pointer;font-size:12px;font-weight:700;transition:transform .1s}
.qi:hover{transform:scale(1.06)}
.qi.ok{background:var(--greenl);border-color:var(--green);color:var(--green)}
.qi.wrong{background:var(--redl);border-color:var(--red);color:var(--red)}
.qi.pend{background:var(--bg);color:var(--muted)}
.qi.cur{outline:2.5px solid var(--ink)}
.mclose{width:100%;margin-top:14px;border:none;border-radius:11px;padding:13px;font-size:14px;font-weight:700;cursor:pointer;background:var(--ink);color:#fff}
/* RESULT */
.res-hero{border-radius:var(--r);padding:26px 22px;text-align:center;margin-bottom:14px;color:#fff}
.res-big{font-size:72px;font-weight:900;letter-spacing:-3px;line-height:1}
.res-sub{font-size:15px;opacity:.75;margin-top:4px;font-weight:700}
.res-pct{font-size:14px;font-weight:800;margin-top:6px;padding:4px 14px;border-radius:99px;display:inline-block}
.res-pct.good{background:var(--greenl);color:var(--green)}
.res-pct.mid{background:var(--warnl);color:var(--warn)}
.res-pct.bad{background:var(--redl);color:var(--red)}
.res-msg{font-size:15px;opacity:.85;margin-top:12px;line-height:1.5}
.byT{background:var(--card);border-radius:var(--r);padding:18px;box-shadow:var(--sh);margin-bottom:14px}
.byT-t{font-size:11px;text-transform:uppercase;letter-spacing:.14em;font-weight:800;color:var(--muted);margin-bottom:12px}
.trow{display:flex;align-items:center;gap:8px;padding:8px 0;border-top:1px solid var(--line)}
.trow:last-child{border-bottom:1px solid var(--line)}
.tname{flex:1;font-size:13px;font-weight:700;min-width:0}
.tbar{width:68px;height:5px;background:var(--line);border-radius:99px;overflow:hidden;flex:none}
.tfill{height:100%}
.tpct{font-size:12px;font-weight:800;width:34px;text-align:right;flex:none}
.tbadge{font-size:10px;font-weight:800;padding:2px 7px;border-radius:5px;flex:none}
.tbadge.ok{background:var(--greenl);color:var(--green)}
.tbadge.mid{background:var(--warnl);color:var(--warn)}
.tbadge.bad{background:var(--redl);color:var(--red)}
.abox{border-radius:var(--r);padding:16px;margin-bottom:14px;border:1.5px solid #f0c060;background:#fff9ee}
.at{font-size:13px;font-weight:900;color:#8a5500;margin-bottom:10px}
.ai{font-size:13px;color:#5a3a00;line-height:1.5;display:flex;gap:8px;margin-bottom:5px}
.rbtn{width:100%;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:800;cursor:pointer;color:#fff;margin-bottom:8px}
.hlnk{display:block;text-align:center;font-size:14px;color:var(--muted);cursor:pointer;text-decoration:underline;padding:8px}
</style>
</head>
