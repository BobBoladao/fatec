"Brasil República":"República Velha, Vargas, ditadura militar, redemocratização.",
"Brasil contemporâneo":"CF/1988, Plano Real, democracia.",
"História Mundial":"Revoluções, guerras mundiais, Guerra Fria.",
"História geral":"Fascismo, Holocausto, descolonização.",
"América Latina":"Revolução Cubana, ditaduras, Mercosul.",
"Movimentos sociais":"Feminismo, modernismo, movimentos operários.",
"Globalização":"Integração, desigualdades, críticas.",
"História do trabalho":"CLT, sindicalismo, Rev. Industrial e trabalhadores.",
"Geopolítica histórica":"OTAN, Apartheid, Guerra Fria.",
"História econômica":"1929, Bretton Woods, neoliberalismo.",
"Atualidades históricas":"4ª Rev. Industrial, pandemia, conflitos atuais.",
"Civilizações antigas":"Grécia, Roma, Egito — contribuições para o Ocidente.",
"Renascimento":"Humanismo, racionalismo, arte e ciência.",
"Reforma protestante":"Lutero, Calvino, consequências políticas.",
"Imperialismo":"Neocolonialismo, causas e consequências.",
"Brasil/tecnologia":"Proálcool, agronegócio, desindustrialização.",
"Cartografia":"Escala, coordenadas, projeções, fusos.",
"Brasil — relevo e clima":"Relevo, bacias hidrográficas, climas do Brasil.",
"Brasil — biomas":"Amazônia, Cerrado, Caatinga, Pantanal, Mata Atlântica.",
"Brasil — população":"Distribuição, densidade, urbanização.",
"Brasil — economia":"Agronegócio, indústria, serviços, comércio exterior.",
"Brasil — urbanização":"Megalópoles, favelas, infraestrutura urbana.",
"Geopolítica mundial":"ONU, blocos econômicos, geopolítica atual.",
"Globalização":"Integração, multinacionais, desigualdades.",
"Meio ambiente":"Acordos climáticos, desmatamento, energias renováveis.",
"Urbanização mundial":"Megalópoles, macrocefalia, urbanização nos países em desenvolvimento.",
"Energia":"Matriz energética, hidrelétricas, renováveis.",
"Regiões do Brasil":"Sudeste, Norte, Nordeste, Sul, Centro-Oeste.",
"Geopolítica Sul-Americana":"Fronteiras, Mercosul, tensões regionais.",
"Comércio internacional":"Balança comercial, termos de troca, OMC.",
"Tecnologia e geografia":"TICs, agricultura de precisão, espaço geográfico digital."
};

// ── STATE ──
var ST={si:0,idx:0,ans:[],sel:null};
function SB(){return SB_data;}
var SB_data;
function L(i){return String.fromCharCode(65+i);}

function show(id){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('on');});
  var home=document.getElementById('sc-home');
  home.classList.remove('on');
  if(id==='sc-home'){home.classList.add('on');}
  else{document.getElementById(id).classList.add('on');}
  window.scrollTo(0,0);
}

function startQ(si){
  ST.si=si;ST.idx=0;ST.sel=null;
  SB_data=SB[si];
  ST.ans=new Array(SB_data.q.length).fill(null);
  show('sc-quiz');
  render();
}

function render(){
  var s=SB_data;var q=s.q[ST.idx];
  var answered=ST.ans[ST.idx]!==null;
  var scoreOk=ST.ans.filter(function(a){return a===true;}).length;
  var prog=Math.round(((ST.idx+(answered?1:0))/s.q.length)*100);

  var dots='';
  for(var i=0;i<s.q.length;i++){
    var dc='d ';
    if(ST.ans[i]===true)dc+='ok';
    else if(ST.ans[i]===false)dc+='wrong';
    else dc+='pend';
    if(i===ST.idx)dc+=' cur';
    dots+='<div class="'+dc+'" onclick="gotoQ('+i+')" title="Q'+(i+1)+'"></div>';
  }

  var opts='';
  for(var j=0;j<q.o.length;j++){
    var oc='';
    if(answered){
      if(j===q.c)oc='ok';
      else if(j===ST.sel)oc='err';
      else oc='dim';
    }
    opts+='<button class="opt '+oc+'" '+(answered?'disabled':'')+' onclick="choose('+j+')">'
      +'<span class="ol">'+L(j)+'</span><span>'+q.o[j]+'</span></button>';
  }

  var fb='';
  if(answered){
    var ok=ST.ans[ST.idx]===true;
    fb='<div class="fb '+(ok?'ok':'err')+'">'
      +'<div class="fb-top"><span class="fb-ico">'+(ok?'✅':'❌')+'</span>'
      +'<div><div class="fb-v">'+(ok?'Correto!':'Resposta: '+L(q.c))+'</div></div></div>'
      +'<div class="fb-why">'+q.w+'</div></div>';
  }

  var nxtL=ST.idx>=s.q.length-1?'Ver resultado':(answered?'Próxima →':'Pular →');
  var html='<div class="qhdr">'
    +'<button class="hbtn" onclick="show(\'sc-home\')">←</button>'
    +'<div class="qhdr-info">'
    +'<div class="qhdr-name" style="color:'+s.ac+'">'+s.ico+' '+s.name+'</div>'
    +'<div class="qhdr-meta">Q '+(ST.idx+1)+'/'+s.q.length+'</div></div>'
    +'<div class="spill">✓ '+scoreOk+'/'+s.q.length+'</div></div>'
    +'<div class="pgrow"><div class="pgbar"><div class="pgfill" style="width:'+prog+'%;background:'+s.ac+'"></div></div>'
    +'<span class="pglbl">'+prog+'%</span></div>'
    +'<div class="dotrow">'+dots+'</div>'
    +'<div class="qcard">'
    +'<div class="qtag"><span class="qn" style="color:'+s.ac+'">Q'+(ST.idx+1)+'</span> · '+q.t+'</div>'
    +'<div class="qtext">'+q.q+'</div>'
    +opts+fb+'</div>'
    +'<button class="listbtn" onclick="openM()">📋 Lista de questões</button>'
    +'<div class="navrow">'
    +'<button class="nb prev" onclick="prevQ()" '+(ST.idx===0?'disabled':'')+'>← Ant.</button>'
    +'<button class="nb" style="background:'+s.ac+';color:'+(s.si===1?'#1a0a2e':'#fff')+'" onclick="nextQ()">'+nxtL+'</button>'
    +'</div>'
    +'<div class="foot">'+(answered?'Leia a explicação.':'Leia com atenção antes de responder.')+'</div>';

  document.getElementById('quiz-inner').innerHTML=html;
}

function choose(i){
  if(ST.ans[ST.idx]!==null)return;
  ST.sel=i;ST.ans[ST.idx]=(i===SB_data.q[ST.idx].c);render();
}
function prevQ(){if(ST.idx>0){ST.idx--;ST.sel=null;render();}}
function nextQ(){if(ST.idx>=SB_data.q.length-1){showResult();return;}ST.idx++;ST.sel=null;render();}
function gotoQ(i){ST.idx=i;ST.sel=null;closeM();render();}

function openM(){
  var html='';
  for(var i=0;i<SB_data.q.length;i++){
    var dc=ST.ans[i]===true?'ok':ST.ans[i]===false?'wrong':'pend';
    var cur=i===ST.idx?' cur':'';
    html+='<div class="qi '+dc+cur+'" onclick="gotoQ('+i+')">'+(i+1)+'</div>';
  }
  document.getElementById('mgrid').innerHTML=html;
  document.getElementById('modal').classList.add('on');
}
function closeM(){document.getElementById('modal').classList.remove('on');}
function maybeClose(e){if(e.target===document.getElementById('modal'))closeM();}

function showResult(){
  var s=SB_data;
  var scoreOk=ST.ans.filter(function(a){return a===true;}).length;
  var total=s.q.length;
  var pct=Math.round((scoreOk/total)*100);
  var msg=pct>=85?'Excelente! Domínio real. Vai arrasar na FATEC! 🚀'
    :pct>=70?'Muito bom! Com esse desempenho você estaria dentro. Afine os erros. 💪'
    :pct>=50?'No caminho. Foque nos tópicos abaixo nos dias que restam. 📖'
    :'Revise com foco. Cada hora conta — você consegue! 🌟';
  var pctClass=pct>=70?'good':pct>=50?'mid':'bad';

  var byT={};
  for(var i=0;i<total;i++){
    var t=s.q[i].t;
    if(!byT[t])byT[t]={ok:0,n:0};
    byT[t].n++;
    if(ST.ans[i]===true)byT[t].ok++;
  }
  var topics=Object.keys(byT).sort(function(a,b){
    return (byT[a].ok/byT[a].n)-(byT[b].ok/byT[b].n);
  });

  var trows='';var critical=[];var medium=[];
  topics.forEach(function(t){
    var p=Math.round((byT[t].ok/byT[t].n)*100);
    var fill=p>=70?'var(--green)':p>=50?'var(--warn)':'var(--red)';
    var badge=p>=70?'<span class="tbadge ok">OK</span>'
      :p>=50?'<span class="tbadge mid">Reforçar</span>'
      :'<span class="tbadge bad">PRIORIDADE</span>';
    trows+='<div class="trow"><div class="tname">'+t+'</div>'
      +'<div class="tbar"><div class="tfill" style="width:'+p+'%;background:'+fill+'"></div></div>'
      +'<div class="tpct" style="color:'+fill+'">'+p+'%</div>'+badge+'</div>';
    if(p<50)critical.push(t);
    else if(p<70)medium.push(t);
  });

  var actions='';
  critical.forEach(function(t){
    var d=TIPS[t]||'Revise o conteúdo e faça mais exercícios.';
    actions+='<div class="ai"><span>🔴</span><div><strong>'+t+'</strong><br>'+d+'</div></div>';
  });
  medium.forEach(function(t){
    var d=TIPS[t]||'Revise os erros e pratique mais.';
    actions+='<div class="ai"><span>⚠️</span><div><strong>'+t+'</strong><br>'+d+'</div></div>';
  });
  if(!actions)actions='<div class="ai"><span>✅</span><div>Ótimo! Revisão rápida e durma bem. Você está preparado!</div></div>';

  document.getElementById('res-inner').innerHTML=
    '<div class="res-hero" style="background:'+s.bg+'">'
    +'<div class="res-big">'+scoreOk+'<span style="font-size:26px;opacity:.5">/'+total+'</span></div>'
    +'<div class="res-sub">'+s.ico+' '+s.name+'</div>'
    +'<div class="res-pct '+pctClass+'">'+pct+'% de acerto</div>'
    +'<div class="res-msg">'+msg+'</div></div>'
    +'<div class="abox"><div class="at">📌 Plano de revisão — '+s.name+'</div>'+actions+'</div>'
    +'<div class="byT"><div class="byT-t">📊 Desempenho por tópico (pior → melhor)</div>'+trows+'</div>'
    +'<button class="rbtn" style="background:'+s.ac+';color:'+(ST.si===1?'#1a0a2e':'#fff')+'" onclick="startQ('+ST.si+')">Refazer este simulado</button>'
    +'<div class="hlnk" onclick="show(\'sc-home\')">← Escolher outra matéria</div>'
    +'<div style="text-align:center;font-size:12px;color:var(--muted);margin-top:20px">FATEC 28/06/2026 · Bora Leo! 💪</div>';
  show('sc-result');
}
</script>
</body>
</html>
