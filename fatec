{name:"Inglês",ico:"🇧🇷🇺🇸",bg:"#0a2a3a",ac:"#00bcd4",
q:[
{t:"Reading comprehension",q:"Read: 'Technology is changing the way we work and communicate.' The main idea is that:",o:["Technology transforms work and communication","Technology is expensive","Work is difficult today","Communication was better before"],c:0,w:"The sentence states technology changes how we work and communicate — that's the main idea."},
{t:"Reading comprehension",q:"'Despite the rain, they decided to go to the beach.' 'Despite' introduces:",o:["A contrast/concession","A reason","A result","An addition"],c:0,w:"'Despite' = apesar de. Introduces contrast/concession — similar to 'embora' in Portuguese."},
{t:"Reading comprehension",q:"'The meeting was postponed due to technical problems.' The meeting was:",o:["Moved to a later date","Cancelled permanently","Moved to an earlier date","Held as planned"],c:0,w:"'Postponed' = adiado. The meeting was moved to a later time."},
{t:"Reading comprehension",q:"'She has been working here for five years.' This means she:",o:["Started 5 years ago and still works here","Worked here 5 years ago and left","Will work here for 5 years","Worked here exactly 5 years"],c:0,w:"Present Perfect Continuous: action started in the past and continues now."},
{t:"Reading comprehension",q:"'If you study hard, you will pass the exam.' This sentence expresses:",o:["A real future condition","An unreal/hypothetical condition","A past habit","A command"],c:0,w:"First conditional (if + present, will + inf) = real, possible future condition."},
{t:"Grammar",q:"'She ___ to school every day.' Complete with the correct verb form:",o:["goes","go","is going","went"],c:0,w:"Simple Present for habitual actions. She (3rd person) → goes."},
{t:"Grammar",q:"'They ___ playing football when it started raining.' Correct form:",o:["were","are","was","had been"],c:0,w:"Past Continuous: were + verb-ing. Used for action in progress interrupted by another."},
{t:"Grammar",q:"'I have never ___ to Japan.' Correct form:",o:["been","went","go","going"],c:0,w:"Present Perfect + never: 'have never been'. 'Been' = past participle of 'be/go'."},
{t:"Grammar",q:"Choose the correct question tag: 'She is your teacher, ___?'",o:["isn't she","is she","doesn't she","wasn't she"],c:0,w:"Positive statement → negative tag. 'is' → 'isn't she?'"},
{t:"Grammar",q:"'He is taller ___ his brother.' Complete:",o:["than","then","that","as"],c:0,w:"Comparative: taller than. 'Than' introduces the second element of comparison."},
{t:"Grammar",q:"'This is the ___ movie I've ever seen.' Superlative:",o:["best","better","good","more good"],c:0,w:"Superlative of 'good' = best. Irregular: good→better→best."},
{t:"Grammar",q:"'If I ___ you, I would study more.' Correct form:",o:["were","am","was","be"],c:0,w:"Second conditional: if + past subjunctive (were for all persons in formal English)."},
{t:"Grammar",q:"'The report ___ by the manager yesterday.' Passive voice:",o:["was written","wrote","has written","is written"],c:0,w:"Passive voice: was/were + past participle. Yesterday = past → was written."},
{t:"Grammar",q:"'She asked me ___ I had finished the project.' Indirect speech:",o:["if","that","what","whether or if"],c:0,w:"Yes/no questions in indirect speech use 'if' or 'whether'."},
{t:"Grammar",q:"'I wish I ___ fly.' Express a wish:",o:["could","can","will","would"],c:0,w:"'I wish + past modal': I wish I could fly (unreal wish in the present)."},
{t:"Vocabulary",q:"'Affordable' means:",o:["priced reasonably / that one can pay for","expensive","unavailable","unreliable"],c:0,w:"Affordable = com preço acessível, que se pode pagar. Common in FATEC tech contexts."},
{t:"Vocabulary",q:"'Breakthrough' in technology means:",o:["an important discovery or advance","a failure","a regular update","a breakdown"],c:0,w:"Breakthrough = avanço importante, descoberta significativa."},
{t:"Vocabulary",q:"'Outsource' means:",o:["to hire an external company to do work","to fire employees","to work overtime","to upgrade software"],c:0,w:"Outsource = terceirizar: contratar empresa externa para realizar um serviço."},
{t:"Vocabulary",q:"'Deadline' means:",o:["the final date by which something must be done","the first day of a project","a type of software","a meeting point"],c:0,w:"Deadline = prazo final, data limite para entrega de um trabalho."},
{t:"Vocabulary",q:"'State-of-the-art' technology is:",o:["the most modern and advanced available","outdated","affordable","simple to use"],c:0,w:"State-of-the-art = de última geração, o mais avançado disponível."},
{t:"Vocabulary",q:"'User-friendly' software is:",o:["easy to use and understand","expensive","powerful","fast"],c:0,w:"User-friendly = fácil de usar, com boa usabilidade — essencial em ADS."},
{t:"Vocabulary",q:"'To launch' a product means:",o:["to introduce it to the market officially","to remove it from sale","to test it internally","to update it"],c:0,w:"Launch = lançar (um produto, aplicativo, site) ao mercado."},
{t:"Technology vocabulary",q:"'Bug' in software refers to:",o:["an error or defect in the program","a computer virus","a type of file","a new feature"],c:0,w:"Bug = erro ou defeito no código que causa comportamento inesperado."},
{t:"Technology vocabulary",q:"'Cloud computing' means:",o:["storing and processing data on remote servers via the internet","a weather forecasting system","a type of computer chip","offline data storage"],c:0,w:"Cloud computing = computação em nuvem: armazenamento e processamento de dados em servidores remotos."},
{t:"Technology vocabulary",q:"'Open source' software is:",o:["software with publicly available source code that can be modified","software that costs nothing to buy","software with no updates","software made by one company only"],c:0,w:"Open source = código aberto: o código-fonte é público e pode ser modificado pela comunidade."},
{t:"Technology vocabulary",q:"'UX' in UX Design stands for:",o:["User Experience","Universal Extension","Unique Export","User Execution"],c:0,w:"UX = User Experience (experiência do usuário): como o usuário interage e sente ao usar um produto digital."},
{t:"Technology vocabulary",q:"'API' stands for:",o:["Application Programming Interface","Advanced Program Integration","Automated Processing Input","Application Procedure Index"],c:0,w:"API = Application Programming Interface: permite que sistemas diferentes se comuniquem."},
{t:"Technology vocabulary",q:"'Bandwidth' in internet refers to:",o:["the maximum rate of data transfer across a network","the physical size of a cable","the number of connected devices","the cost of internet access"],c:0,w:"Bandwidth = largura de banda: capacidade máxima de transferência de dados em uma rede."},
{t:"Reading — technology",q:"Read: 'Artificial intelligence is transforming industries by automating tasks previously performed by humans.' AI is:",o:["taking over tasks humans used to do","replacing all workers immediately","reducing internet usage","increasing manual labor"],c:0,w:"'Automating tasks previously performed by humans' = automatizando tarefas antes feitas por humanos."},
{t:"Reading — technology",q:"'Data privacy has become a major concern as companies collect increasing amounts of personal information.' The text says data privacy:",o:["is increasingly important","is no longer relevant","has been solved","only affects governments"],c:0,w:"'Major concern' = preocupação importante. Privacy is increasingly relevant as data collection grows."},
{t:"Reading — technology",q:"'Start-ups face many challenges, including limited funding and fierce competition.' What challenges do start-ups face?",o:["Lack of money and strong competition","Too many employees","Government support issues only","International laws"],c:0,w:"'Limited funding' = pouco dinheiro / financiamento limitado. 'Fierce competition' = concorrência forte."},
{t:"Reading — technology",q:"'The company was founded in 2005 and went public in 2010.' 'Went public' means:",o:["started selling shares on the stock market","became a government company","opened new offices","closed down"],c:0,w:"'Go public' = abrir capital na bolsa de valores (IPO)."},
{t:"Grammar — technology context",q:"'Software ___ regularly to fix security issues.' Correct passive:",o:["should be updated","should update","must updating","is update"],c:0,w:"Modal passive: modal + be + past participle. 'Should be updated.'"},
{t:"Grammar — technology context",q:"'By the time the app was launched, the team ___ for two years.' Correct form:",o:["had been working","was working","worked","has worked"],c:0,w:"Past Perfect Continuous: action ongoing before a specific past moment."},
{t:"Grammar — technology context",q:"'The new system is ___ efficient ___ the old one.' Comparative:",o:["more / than","most / than","more / that","most / of"],c:0,w:"Comparative with long adjectives: more + adjective + than."},
{t:"Prepositions",q:"'She is responsible ___ the database management.'",o:["for","of","to","with"],c:0,w:"Responsible for = responsável por."},
{t:"Prepositions",q:"'The project was completed ___ time.'",o:["on","in","at","by"],c:0,w:"'On time' = no prazo, pontualmente."},
{t:"Prepositions",q:"'He specializes ___ cybersecurity.'",o:["in","on","at","for"],c:0,w:"Specialize in = especializar-se em."},
{t:"Modal verbs",q:"'You ___ submit the form before the deadline.' (obligation)",o:["must","might","could","should"],c:0,w:"Must = obrigação. Should = recomendação. Might = possibilidade."},
{t:"Modal verbs",q:"'She ___ speak three languages.' (ability in the past)",o:["could","must","should","would"],c:0,w:"Could = habilidade no passado (era capaz de)."},
{t:"Modal verbs",q:"'It ___ rain later. Bring an umbrella.' (possibility)",o:["might","must","will","shall"],c:0,w:"Might = possibilidade (pode ser que chova)."},
{t:"Connectors",q:"'The project was late; ___, the client was understanding.' Correct connector:",o:["however","therefore","moreover","furthermore"],c:0,w:"However = entretanto, porém. Indicates contrast/concession."},
{t:"Connectors",q:"'We need to reduce costs. ___, we must maintain quality.'",o:["However","Therefore","Moreover","Although"],c:0,w:"However = porém. Introduces contrasting information."},
{t:"Connectors",q:"'She studied hard. ___, she passed the exam.'",o:["As a result","However","Although","Unless"],c:0,w:"As a result = como resultado. Introduces consequence."},
{t:"False friends",q:"'Pretend' in English means:",o:["fingir (to fake)","pretender (to intend)","precisar (to need)","esperar (to wait)"],c:0,w:"False friend: 'pretend' = fingir (NOT pretender). 'I pretend I'm sick' = finjo estar doente."},
{t:"False friends",q:"'Actually' in English means:",o:["na verdade / de fato","atualmente","eventualmente","normalmente"],c:0,w:"False friend: 'actually' = na verdade / de fato (NOT atualmente). 'Currently' = atualmente."},
{t:"False friends",q:"'Eventually' in English means:",o:["eventualmente = com o tempo / por fim","na verdade","provavelmente","normalmente"],c:0,w:"'Eventually' = no fim das contas, com o tempo (NOT às vezes como em português)."},
{t:"False friends",q:"'Sensible' in English means:",o:["sensato / razoável","sensível","sentimental","sentido"],c:0,w:"'Sensible' = sensato (NOT sensível). 'Sensitive' = sensível em inglês."},
{t:"Reading — general",q:"'The government announced new measures to reduce carbon emissions.' The government wants to:",o:["decrease pollution from carbon","increase energy prices","promote fossil fuels","reduce recycling"],c:0,w:"Carbon emissions = emissões de carbono. Reduce = diminuir. The government wants to reduce pollution."},
{t:"Reading — general",q:"'Despite being expensive, electric cars are becoming more popular.' Why might people still buy them?",o:["They are becoming more popular, likely for environmental/fuel savings reasons","They are cheap","They are faster than regular cars","They require less maintenance"],c:0,w:"'Despite being expensive' shows the cost is a drawback, yet popularity grows — implying other benefits."},
{t:"Reading — general",q:"'The startup raised $10 million in its Series A funding round.' This means the startup:",o:["received investment money","lost $10 million","went bankrupt","was acquired"],c:0,w:"'Raised funding' = captou investimento. Series A = primeira rodada significativa de investimento."}
]},

