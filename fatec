{name:"História",ico:"🏛️",bg:"#3a2a0a",ac:"#ff9800",
q:[
{t:"Brasil colonial",q:"O sistema de capitanias hereditárias (1532) foi criado para:",o:["Colonizar o Brasil dividindo-o em faixas entregues a donatários","Abolir a escravidão indígena","Criar municípios autônomos","Expulsar os franceses"],c:0,w:"Capitanias hereditárias: 15 faixas doadas a 12 donatários para colonizar e defender o território."},
{t:"Brasil colonial",q:"O Pacto Colonial (exclusivo metropolitano) determinava que as colônias:",o:["Só podiam comerciar com a metrópole, garantindo lucro para Portugal","Podiam comerciar livremente","Eram autônomas economicamente","Exportavam manufaturados"],c:0,w:"Pacto Colonial: colônia fornece matérias-primas e compra manufaturados exclusivamente da metrópole."},
{t:"Brasil colonial",q:"A Inconfidência Mineira (1789) foi motivada principalmente pela:",o:["Derrama (cobrança excessiva de impostos) e influência iluminista","Abolição da escravidão","Invasão portuguesa","Independência dos EUA"],c:0,w:"Inconfidência: reação à opressão fiscal (derrama) e influência do Iluminismo e da Independência americana."},
{t:"Brasil Império",q:"A independência do Brasil (1822) foi proclamada por:",o:["D. Pedro I às margens do Ipiranga","D. João VI no Rio de Janeiro","Tiradentes em Minas Gerais","Simón Bolívar"],c:0,w:"Independência: 7/9/1822 — D. Pedro I proclama 'Independência ou Morte' (Grito do Ipiranga)."},
{t:"Brasil Império",q:"O período regencial (1831-1840) foi marcado por:",o:["Instabilidade política e revoltas regionais (Cabanagem, Balaiada, Sabinada, Farroupilha)","Paz e prosperidade","Grande desenvolvimento industrial","União com Portugal"],c:0,w:"Regência: D. Pedro I abdicou em 1831. Período de revoltas regionais até a maioridade de D. Pedro II (1840)."},
{t:"Brasil Império",q:"A Lei Áurea (1888) aboliu:",o:["A escravidão no Brasil","As capitanias hereditárias","O regime imperial","A monarquia constitucional"],c:0,w:"Lei Áurea (13/5/1888), assinada pela Princesa Isabel: aboliu definitivamente a escravidão no Brasil."},
{t:"Brasil República",q:"A República Velha (1889-1930) foi marcada pela política do 'café com leite' que representa:",o:["Alternância no poder entre São Paulo (café) e Minas Gerais (leite)","Aliança entre Brasil e Portugal","Política econômica para pobres","Reforma agrária"],c:0,w:"Café com leite: oligarquias cafeeiras de SP e pecuaristas de MG se revezavam na presidência."},
{t:"Brasil República",q:"A Revolução de 1930 levou ao poder:",o:["Getúlio Vargas, encerrando a República Velha","Dom Pedro III","Rui Barbosa","Epitácio Pessoa"],c:0,w:"Revolução de 1930: movimento que colocou Getúlio Vargas no poder, encerrando a hegemonia oligárquica."},
{t:"Brasil República",q:"O Estado Novo (1937-1945) foi um regime:",o:["Ditatorial instaurado por Vargas com Constituição autoritária ('Polaca')","Democrático e liberal","Militar sem partido","Monarquista"],c:0,w:"Estado Novo: ditadura de Vargas. Fechou o Congresso, censurou a imprensa, perseguiu opositores."},
{t:"Brasil República",q:"(FATEC) O AI-5 (1968), durante a ditadura militar, ficou conhecido como:",o:["O ato mais duro, que suspendeu direitos políticos e fechou o Congresso","A lei que garantiu eleições livres","O decreto que aboliu a censura","O início da redemocratização"],c:0,w:"AI-5 (13/12/1968): suspendeu habeas corpus, fechou Congresso, instaurou censura — marco da repressão militar."},
{t:"Brasil contemporâneo",q:"A Constituição Federal de 1988 ficou conhecida como:",o:["Constituição Cidadã (Ulysses Guimarães) — marcou a redemocratização","Constituição do Império","Constituição Polaca","Constituição de 1946"],c:0,w:"CF/1988: 'Constituição Cidadã'. Ampliou direitos fundamentais após 21 anos de ditadura militar."},
{t:"Brasil contemporâneo",q:"O Plano Real (1994) foi implementado para:",o:["Controlar a hiperinflação e estabilizar a economia brasileira","Privatizar empresas estatais","Criar o Mercosul","Pagar a dívida externa"],c:0,w:"Plano Real: criou nova moeda (R$), ancoragem cambial e controle monetário → fim da hiperinflação."},
{t:"História Mundial",q:"A Revolução Francesa (1789) foi motivada por:",o:["Crise econômica, desigualdade social e ideias iluministas","Invasão inglesa","Disputa religiosa","Revolução industrial"],c:0,w:"Rev. Francesa: crise fiscal, desigualdade (Estates System) e Iluminismo. Lema: Liberdade, Igualdade, Fraternidade."},
{t:"História Mundial",q:"A Revolução Industrial começou na:",o:["Inglaterra (séc. XVIII)","França (séc. XIX)","Alemanha (séc. XVII)","EUA (séc. XVIII)"],c:0,w:"Rev. Industrial: iniciou na Inglaterra (séc. XVIII) com a máquina a vapor. Transformou produção e sociedade."},
{t:"História Mundial",q:"A 1ª Guerra Mundial (1914-1918) terminou com:",o:["Tratado de Versalhes, que humilhou a Alemanha e gerou condições para a 2ª Guerra","Vitória alemã","Empate entre as potências","Criação da ONU"],c:0,w:"Tratado de Versalhes (1919): cláusula da culpa exclusiva da Alemanha, reparações pesadas → crise que favoreceu o nazismo."},
{t:"História Mundial",q:"A 2ª Guerra Mundial terminou em 1945 com:",o:["Derrota do Eixo (Alemanha, Itália, Japão) e criação da ONU","Vitória alemã","Armistício sem vencedor","Divisão do mundo em 3 blocos"],c:0,w:"1945: capitulação da Alemanha (maio) e Japão (agosto, após bombas atômicas). Criação da ONU em outubro."},
{t:"História Mundial",q:"A Guerra Fria (1947-1991) foi o confronto entre:",o:["EUA (capitalismo) e URSS (socialismo) sem conflito armado direto","EUA e China","Europa e Ásia","OTAN e ONU"],c:0,w:"Guerra Fria: disputa ideológica, econômica e tecnológica entre EUA e URSS. Dividiu o mundo em blocos."},
{t:"História Mundial",q:"A Queda do Muro de Berlim (1989) simbolizou:",o:["O fim da Guerra Fria e da divisão da Alemanha","O início da 2ª Guerra","A reunificação da URSS","O fortalecimento do comunismo"],c:0,w:"Queda do Muro (9/11/1989): início da reunificação alemã e sinal do colapso do socialismo soviético."},
{t:"História Mundial",q:"(FATEC) A Revolução Russa (1917) instaurou:",o:["O primeiro Estado socialista do mundo (liderado por Lenin e os bolcheviques)","Uma monarquia constitucional","Uma república democrática liberal","Um regime nazifascista"],c:0,w:"Revolução de Outubro/1917: bolcheviques (Lenin) tomam poder → URSS (1922) = primeiro Estado socialista."},
{t:"História geral",q:"O fascismo italiano (Mussolini) e o nazismo alemão (Hitler) são ideologias:",o:["Ultranacionalistas, totalitárias e de extrema-direita","Socialistas e de esquerda","Liberais e democráticas","Anarquistas"],c:0,w:"Fascismo e nazismo: totalitarismo, ultranacionalismo, culto ao líder, antidemocracia e violência política."},
{t:"História geral",q:"O Holocausto durante a 2ª Guerra foi:",o:["Genocídio de ~6 milhões de judeus e outras minorias pelo regime nazista","Bombardeio das cidades japonesas","Batalha de Stalingrado","Invasão da Normandia"],c:0,w:"Holocausto (Shoah): extermínio sistemático de ~6 milhões de judeus + ciganos, homossexuais, deficientes, etc."},
{t:"História geral",q:"O processo de descolonização da África e Ásia ocorreu principalmente:",o:["Após a 2ª Guerra Mundial (décadas de 1950-60)","Durante a 1ª Guerra","No século XIX","Durante a Guerra Fria antes de 1940"],c:0,w:"Descolonização: após 1945, movimentos independentistas na África e Ásia ganham força. Maioria entre 1950-1970."},
{t:"América Latina",q:"A Revolução Cubana (1959) foi liderada por:",o:["Fidel Castro e Che Guevara","Simón Bolívar","Salvador Allende","Hugo Chávez"],c:0,w:"Rev. Cubana: guerrilha de Castro/Guevara derrubou Batista em 1959 → Cuba socialista → embargo americano."},
{t:"América Latina",q:"O Mercosul foi criado em 1991 para:",o:["Integração econômica entre Brasil, Argentina, Uruguai e Paraguai","Criar moeda única na América Latina","Substituir a OEA","Combater o narcotráfico"],c:0,w:"Mercosul: bloco econômico de integração regional criado pelo Tratado de Assunção (1991)."},
{t:"Movimentos sociais",q:"A Semana de Arte Moderna de 1922 no Brasil representou:",o:["Ruptura com o academicismo e busca de identidade cultural brasileira","O início da industrialização","A proclamação da república","A abolição da escravidão"],c:0,w:"Modernismo 1922: ruptura com padrões europeus, valorização da cultura popular brasileira e língua coloquial."},
{t:"Movimentos sociais",q:"(FATEC) O movimento feminista de 2ª onda (anos 1960-70) lutava por:",o:["Igualdade no trabalho, direito ao corpo e ao voto (em países que ainda não tinham)","Apenas direito ao voto","Igualdade econômica global","Fim do capitalismo"],c:0,w:"2ª onda feminista: igualdade no mercado de trabalho, direitos reprodutivos e questões de gênero."},
{t:"Globalização",q:"A globalização é o processo de:",o:["Integração econômica, cultural e tecnológica mundial acelerada a partir do séc. XX","Divisão do mundo em blocos isolados","Retorno ao mercantilismo","Criação de estados-nação independentes"],c:0,w:"Globalização: integração dos mercados, culturas e informações. Acelerada pela tecnologia e queda do Muro de Berlim."},
{t:"Globalização",q:"Uma crítica à globalização é que ela:",o:["Aprofunda desigualdades entre países ricos e pobres e homogeneíza culturas","Distribui riquezas igualmente","Fortalece todas as culturas locais","Elimina o comércio internacional"],c:0,w:"Crítica: concentração de riqueza nos países centrais, dominação cultural americana/ocidental e vulnerabilidade dos países periféricos."},
{t:"História do trabalho",q:"A CLT (Consolidação das Leis do Trabalho) foi criada no Brasil em:",o:["1943, pelo governo Vargas","1888, com a abolição","1922, pelo movimento operário","1964, pela ditadura"],c:0,w:"CLT (1943): marco da legislação trabalhista brasileira. Criada por Vargas como parte do Estado Novo."},
{t:"História do trabalho",q:"A Revolução Industrial gerou para os trabalhadores inicialmente:",o:["Jornadas exaustivas, trabalho infantil, péssimas condições e baixos salários","Melhoria imediata das condições de vida","Redução do horário de trabalho","Criação de sindicatos livres"],c:0,w:"Primórdios da Rev. Industrial: exploração intensa do trabalho, incluindo crianças. Levou ao movimento operário e ao socialismo."},
{t:"Geopolítica histórica",q:"A OTAN (NATO) é uma aliança militar criada em 1949 entre:",o:["EUA, Canadá e países da Europa Ocidental (defesa contra URSS)","URSS e aliados socialistas","Países latino-americanos","China e aliados asiáticos"],c:0,w:"OTAN: Organização do Tratado do Atlântico Norte. Aliança militar ocidental criada no contexto da Guerra Fria."},
{t:"Geopolítica histórica",q:"O Apartheid na África do Sul foi um sistema de:",o:["Segregação racial institucionalizada que durou até 1994","Colonialismo britânico","Ditadura militar sem base racial","União de povos africanos"],c:0,w:"Apartheid (1948-1994): segregação racial institucional na África do Sul. Fim com Nelson Mandela presidente (1994)."},
{t:"História econômica",q:"A Grande Depressão de 1929 foi desencadeada pela:",o:["Quebra da Bolsa de Nova York e colapso do sistema financeiro","1ª Guerra Mundial diretamente","Revolução Russa","Crise do petróleo"],c:0,w:"Crise de 1929: especulação, superprodução e quebra da NYSE → recessão global → desemprego em massa."},
